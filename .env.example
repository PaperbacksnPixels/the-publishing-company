# The Publishing Company — Environment Variables (Template)
# Copy this file to .env and fill in your actual values.
# .env is gitignored so your secrets never end up in version control.

# ============================================================
# Airtable API
# ============================================================
# Get a PAT from: https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write
AIRTABLE_PAT=paste_your_airtable_pat_here
AIRTABLE_BASE_ID=appj8IY8wQ6PhnNOi

# ============================================================
# Flask
# ============================================================
# Generate a real secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NEVER reuse your local dev key in production.
FLASK_SECRET_KEY=generate_a_random_secret_key_here

# Set to "production" on Render, "development" locally.
FLASK_ENV=development

# ============================================================
# Supabase Auth
# ============================================================
# Get these from https://supabase.com after creating a project.
# We only use the anon/publishable key — no service-role key needed.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=paste_your_anon_key_here
